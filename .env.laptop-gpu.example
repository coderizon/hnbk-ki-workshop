# Laptop-GPU variant (Ollama on an NVIDIA laptop GPU). Copy to .env.laptop-gpu
# (gitignored), then:
#   docker compose -f compose.laptop-gpu.yml --env-file .env.laptop-gpu up -d
# Requires a discrete NVIDIA GPU and the NVIDIA Container Toolkit (same prereq as the
# DGX Spark variant). Faster than the CPU laptop variant; still a learning setup.

# ── Images (pinned by digest) ────────────────────────────────────────────────
# Versions: ollama 0.30.7, qdrant 1.15.5, tika 3.2.3-full, open-webui 0.6.36
OLLAMA_IMAGE=ollama/ollama@sha256:46399ef084d97b381955b5dc585c5d836dbe7ed3f79f170d1c04660fed511e3a
QDRANT_IMAGE=qdrant/qdrant@sha256:0fb8897412abc81d1c0430a899b9a81eb8328aa634e7242d1bc804c1fe8fe863
TIKA_IMAGE=apache/tika@sha256:21d8052de04e491ccf66e8680ade4da6f3d453a56d59f740b4167e54167219b7
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui@sha256:53a4d2fc8c7a7cc620cd18e6fe416ed9940f2db87fddf837e3aa55111bec6995

# ── Models (pulled into Ollama on first start) ───────────────────────────────
# gemma4:e4b-it-qat (same tag as the CPU variant, confirmed to exist 2026-06-11).
# A laptop GPU can also run the larger gemma4:e4b (9.6 GB) for better quality —
# confirm the tag still exists before switching, since this variant is unvalidated.
CHAT_MODEL=gemma4:e4b-it-qat
EMBEDDING_MODEL=bge-m3

# ── Host ports ───────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
TIKA_PORT=9998
WEBUI_PORT=3000
