# Laptop variant (Ollama on CPU). Copy to .env.laptop (gitignored), then:
#   docker compose -f compose.laptop.yml --env-file .env.laptop up -d
# Defaults fit a 16GB-RAM laptop. No GPU or token required.

# ── Images (pinned by digest) ────────────────────────────────────────────────
# Versions: ollama 0.30.7, qdrant 1.15.5, tika 3.2.3-full, open-webui 0.6.36
OLLAMA_IMAGE=ollama/ollama@sha256:46399ef084d97b381955b5dc585c5d836dbe7ed3f79f170d1c04660fed511e3a
QDRANT_IMAGE=qdrant/qdrant@sha256:0fb8897412abc81d1c0430a899b9a81eb8328aa634e7242d1bc804c1fe8fe863
TIKA_IMAGE=apache/tika@sha256:21d8052de04e491ccf66e8680ade4da6f3d453a56d59f740b4167e54167219b7
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui@sha256:53a4d2fc8c7a7cc620cd18e6fe416ed9940f2db87fddf837e3aa55111bec6995

# ── Models (pulled into Ollama on first start) ───────────────────────────────
# gemma4:e4b-it-qat is the 4-bit (QAT) E4B build, ~6.1 GB, instruction-tuned.
# For an even lighter machine, gemma4:e2b is smaller; for more RAM, gemma4:e4b.
CHAT_MODEL=gemma4:e4b-it-qat
EMBEDDING_MODEL=bge-m3

# ── Host ports ───────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
TIKA_PORT=9998
WEBUI_PORT=3000
