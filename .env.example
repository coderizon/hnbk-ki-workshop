# Copy to .env (it is gitignored). The defaults below are a working, tested
# configuration for an NVIDIA DGX Spark (GB10). No token or secret is required.

# ── Images (pinned for reproducibility) ──────────────────────────────────────
# vLLM is pinned by its stable dated NGC tag; the others by digest.
# Versions: qdrant 1.15.5, tika 3.2.3-full, open-webui 0.6.36, vLLM 0.10.2+nv25.10
ENGINE_IMAGE=nvcr.io/nvidia/vllm:25.10-py3
EMBEDDING_IMAGE=nvcr.io/nvidia/vllm:25.10-py3
QDRANT_IMAGE=qdrant/qdrant@sha256:0fb8897412abc81d1c0430a899b9a81eb8328aa634e7242d1bc804c1fe8fe863
TIKA_IMAGE=apache/tika@sha256:21d8052de04e491ccf66e8680ade4da6f3d453a56d59f740b4167e54167219b7
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui@sha256:53a4d2fc8c7a7cc620cd18e6fe416ed9940f2db87fddf837e3aa55111bec6995

# ── Models ───────────────────────────────────────────────────────────────────
CHAT_MODEL=nvidia/NVIDIA-Nemotron-Nano-9B-v2-NVFP4
EMBEDDING_MODEL=BAAI/bge-m3

# ── GPU memory split (chat + embedding share one GB10; the two must sum < 1.0) ─
CHAT_GPU_FRACTION=0.80
EMBED_GPU_FRACTION=0.10

# ── Chat model serving params ────────────────────────────────────────────────
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=200

# ── Host ports ───────────────────────────────────────────────────────────────
ENGINE_PORT=8000
EMBED_PORT=8081
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
TIKA_PORT=9998
WEBUI_PORT=3000
